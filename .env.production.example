# Domain and HTTPS
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# Database
POSTGRES_DB=celestials_db
POSTGRES_USER=celestials
POSTGRES_PASSWORD=change_me_to_strong_password

# Security
JWT_SECRET=replace_with_minimum_32_char_random_secret

# Payments
NETOPIA_SIGNATURE=replace_with_live_signature
NETOPIA_START_URL=https://secure.netopia-payments.com/payment/card/start
NETOPIA_RETURN_URL=https://your-domain.com/orders
NETOPIA_PUBLIC_CERT_PATH=/app/config/netopia/public.cer
